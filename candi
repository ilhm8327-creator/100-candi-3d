<!DOCTYPE html><html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>100 Candi 3D</title>
<style>
body {
    margin: 0;
    overflow: hidden;
}
canvas {
    display: block;
}
</style>
</head>
<body><script type="module">
import * as THREE from 'https://cdn.jsdelivr.net/npm/three@0.160.0/build/three.module.js';

const scene = new THREE.Scene();
scene.background = new THREE.Color(0xbfdfff);

// Kamera
const camera = new THREE.PerspectiveCamera(
    60,
    window.innerWidth / window.innerHeight,
    0.1,
    1000
);
camera.position.set(40, 25, 40);

// Renderer
const renderer = new THREE.WebGLRenderer({ antialias:true });
renderer.setSize(window.innerWidth, window.innerHeight);
renderer.shadowMap.enabled = true;
document.body.appendChild(renderer.domElement);

// Cahaya
const sun = new THREE.DirectionalLight(0xffffff, 2);
sun.position.set(50, 80, 30);
sun.castShadow = true;
scene.add(sun);

scene.add(new THREE.AmbientLight(0xffffff, 0.5));

// Tanah
const ground = new THREE.Mesh(
    new THREE.PlaneGeometry(150, 150),
    new THREE.MeshStandardMaterial({
        color: 0x4e8f4e
    })
);
ground.rotation.x = -Math.PI / 2;
ground.receiveShadow = true;
scene.add(ground);

// Fungsi membuat candi
function createTemple(x, z) {
    const temple = new THREE.Group();

    const stone = new THREE.MeshStandardMaterial({
        color: 0x6d6d6d
    });

    const base = new THREE.Mesh(
        new THREE.BoxGeometry(3, 1, 3),
        stone
    );

    const body = new THREE.Mesh(
        new THREE.BoxGeometry(2.2, 3, 2.2),
        stone
    );
    body.position.y = 2;

    const roof = new THREE.Mesh(
        new THREE.ConeGeometry(1.8, 3, 4),
        stone
    );
    roof.position.y = 5;
    roof.rotation.y = Math.PI / 4;

    const top = new THREE.Mesh(
        new THREE.SphereGeometry(0.4),
        new THREE.MeshStandardMaterial({
            color: 0xd4af37
        })
    );
    top.position.y = 6.7;

    temple.add(base);
    temple.add(body);
    temple.add(roof);
    temple.add(top);

    temple.position.set(x, 0, z);

    const scale = 0.8 + Math.random() * 0.6;
    temple.scale.set(scale, scale, scale);

    scene.add(temple);
}

// 100 candi (10 x 10)
for (let i = 0; i < 10; i++) {
    for (let j = 0; j < 10; j++) {
        createTemple(
            i * 8 - 36,
            j * 8 - 36
        );
    }
}

// Animasi
function animate() {
    requestAnimationFrame(animate);

    const t = Date.now() * 0.00015;

    camera.position.x = Math.cos(t) * 70;
    camera.position.z = Math.sin(t) * 70;
    camera.position.y = 25 + Math.sin(t * 2) * 5;

    camera.lookAt(0, 0, 0);

    renderer.render(scene, camera);
}

animate();

window.addEventListener('resize', () => {
    camera.aspect = window.innerWidth / window.innerHeight;
    camera.updateProjectionMatrix();
    renderer.setSize(
        window.innerWidth,
        window.innerHeight
    );
});
</script></body>
</html>
